---
import BaseLayout from "@/layouts/BaseLayout.astro"
---

<BaseLayout title="remark-callout Astro Example">
  <main style="max-width: 48rem; margin: 3rem auto; padding: 0 1.5rem; font-family: system-ui, sans-serif;">
    <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">
      remark-callout Astro Example
    </h1>
    <p style="color: #555; margin-bottom: 2rem;">
      This project demonstrates how to use{" "}
      <a href="https://github.com/r4ai/remark-callout" style="color: #2563eb;">
        @r4ai/remark-callout
      </a>{" "}
      in an Astro project.
    </p>

    <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
      <li>
        <a
          href="/custom-components"
          style="display: block; padding: 1.25rem 1.5rem; border: 1px solid #e5e7eb; border-radius: 0.5rem; text-decoration: none; color: inherit; transition: border-color 0.15s;"
        >
          <h2 style="font-size: 1.125rem; font-weight: 600; margin: 0 0 0.25rem;">
            Custom Components
          </h2>
          <p style="margin: 0; color: #6b7280; font-size: 0.875rem;">
            Style callouts using custom React components with Tailwind CSS.
            Uses <code style="font-size: 0.8rem; background: #f3f4f6; padding: 0.1rem 0.3rem; border-radius: 0.25rem;">callout-root</code>,
            <code style="font-size: 0.8rem; background: #f3f4f6; padding: 0.1rem 0.3rem; border-radius: 0.25rem;">callout-title</code>, and
            <code style="font-size: 0.8rem; background: #f3f4f6; padding: 0.1rem 0.3rem; border-radius: 0.25rem;">callout-body</code> custom elements.
          </p>
        </a>
      </li>
      <li>
        <a
          href="/css"
          style="display: block; padding: 1.25rem 1.5rem; border: 1px solid #e5e7eb; border-radius: 0.5rem; text-decoration: none; color: inherit; transition: border-color 0.15s;"
        >
          <h2 style="font-size: 1.125rem; font-weight: 600; margin: 0 0 0.25rem;">
            CSS Styling
          </h2>
          <p style="margin: 0; color: #6b7280; font-size: 0.875rem;">
            Style callouts using plain CSS with the default
            <code style="font-size: 0.8rem; background: #f3f4f6; padding: 0.1rem 0.3rem; border-radius: 0.25rem;">data-callout</code> attributes.
            No JavaScript components required.
          </p>
        </a>
      </li>
    </ul>
  </main>
</BaseLayout>
