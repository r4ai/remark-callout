{
  "name": "website",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "typedoc": "bun run --cwd ../remark-typedoc-astro-link build && typedoc --options typedoc.config.js",
    "dev": "bun run typedoc && bun run astro dev",
    "build": "NODE_ENV=production bun run typedoc && bun run astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check .",
    "lint:write": "biome check --write .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "check": "bun run lint && bun run format",
    "check:write": "bun run lint:write && bun run format:write"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "5.0.2",
    "@astrojs/react": "5.0.1",
    "@monaco-editor/react": "^4.6.0",
    "@prettier/sync": "^0.6.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tailwindcss/vite": "^4.1.17",
    "astro": "6.0.8",
    "dedent": "^1.5.1",
    "katex": "^0.16.9",
    "lucide-react": "^0.545.0",
    "prettier": "^3.2.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-stringify": "^10.0.0",
    "remark-mdx": "^3.1.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.4.2",
    "unified": "^11.0.5",
    "vaul": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@r4ai/remark-callout": "workspace:*",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.13",
    "@types/mdast": "4.0.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.6.14",
    "rehype-katex": "7.0.1",
    "remark-math": "6.0.0",
    "remark-typedoc-astro-link": "workspace:*",
    "shiki": "4.0.2",
    "tailwind-merge": "3.5.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwind-variants": "3.2.2",
    "tw-animate-css": "^1.4.0",
    "typedoc": "0.28.5",
    "typedoc-plugin-frontmatter": "1.3.1",
    "typedoc-plugin-markdown": "4.9.0",
    "typedoc-plugin-missing-exports": "4.1.2",
    "typedoc-plugin-remark": "2.0.1",
    "typedoc-plugin-replace-text": "4.2.0",
    "unist-util-visit": "5.0.0"
  }
